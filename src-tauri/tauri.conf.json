{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wisp-science",
  "version": "0.1.0",
  "identifier": "science.wisp-science.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": { "script": "powershell -ExecutionPolicy Bypass -File sync-vendor.ps1; trunk serve --port 1420", "cwd": "../ui" },
    "beforeBuildCommand": { "script": "powershell -ExecutionPolicy Bypass -File sync-vendor.ps1; trunk build --release", "cwd": "../ui" }
  },
  "app": {
    "windows": [
      { "title": "wisp-science", "width": 1100, "height": 760, "resizable": true }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
